{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": ["apps/**", "packages/**", "!apps/**/dist", "!packages/**/dist"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always"
    }
  }
}
